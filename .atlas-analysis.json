  "keyFeatures": [
    "Production order management and execution tracking",
    "Shift-based bitácora (logbook) system",
    "Real-time incident reporting and management",
    "Quality control with batch (lote) and sample (muestra) tracking",
    "Complete traceability across production chain",
    "Resource consumption tracking and management",
    "Multiple production process support (Telares, Laminado, Imprenta, etc.)",
    "Personnel and group management with role-based access",
    "Weekly production planning",
    "Comprehensive audit logging",
    "Real-time dashboard and analytics",
    "SQLite database with WAL mode for concurrent access"
  ],
